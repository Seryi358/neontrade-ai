# ═══════════════════════════════════════════════════════════
# Atlas Trading App — Environment Variables
# Copy to backend/.env for local dev, or set in EasyPanel UI
# ═══════════════════════════════════════════════════════════

# ── REQUIRED: Broker selection ──────────────────────────────
ACTIVE_BROKER=capital  # "capital" or "ibkr"

# ── REQUIRED: Broker (Capital.com) ──────────────────────────
CAPITAL_API_KEY=your_capital_api_key
CAPITAL_PASSWORD=your_capital_password
CAPITAL_IDENTIFIER=your_email@example.com
CAPITAL_ENVIRONMENT=demo  # "demo" or "live"
# CAPITAL_ACCOUNT_ID=             # Optional: explicit account ID (leave empty for auto-detect)

# ── OPTIONAL: Broker (IBKR Web API) ─────────────────────────
# IBKR_CONSUMER_KEY=
# IBKR_ACCESS_TOKEN=
# IBKR_ACCESS_TOKEN_SECRET=
# IBKR_KEYS_DIR=keys

# ── REQUIRED: AI Analysis (OpenAI GPT-4o, informational only) ─
OPENAI_API_KEY=sk-your_openai_key

# ── REQUIRED: App Security ──────────────────────────────────
# Used to generate the first API key and for same-origin auth injection
API_SECRET_KEY=generate-a-random-32-char-string

# ── OPTIONAL: News Feeds (calendar + headlines) ─────────────
# FINNHUB_API_KEY=your_finnhub_key
# NEWSAPI_KEY=your_newsapi_key

# ── OPTIONAL: Alerts — Gmail (OAuth2, preferred) ────────────
# GMAIL_SENDER=your-gmail@gmail.com
# GMAIL_RECIPIENT=target@example.com
# GMAIL_CLIENT_ID=...apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# ── OPTIONAL: Alerts — SMTP Email (legacy / fallback) ───────
# ALERT_EMAIL_SMTP_SERVER=smtp.gmail.com
# ALERT_EMAIL_SMTP_PORT=587
# ALERT_EMAIL_USERNAME=your@example.com
# ALERT_EMAIL_PASSWORD=your_app_password
# ALERT_EMAIL_RECIPIENT=you@example.com

# ── OPTIONAL: Alerts — Telegram / Discord ───────────────────
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── OPTIONAL: Push notifications (Firebase FCM) ─────────────
# FCM_SERVER_KEY=your_fcm_server_key

# ── OPTIONAL: Overrides ─────────────────────────────────────
# APP_HOST=0.0.0.0
# APP_PORT=8000
# LOG_LEVEL=INFO

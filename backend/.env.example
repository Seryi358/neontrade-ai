# ── NeonTrade AI - Environment Variables ──────────────────────
# Copy to .env and fill in your values.
# For EasyPanel: add these as environment variables in app config.

# ── Broker Selection ───────────────────────────────────────────
# Options: "capital", "ibkr", "oanda"
ACTIVE_BROKER=capital

# ── Capital.com API ───────────────────────────────────────────
CAPITAL_API_KEY=your_api_key_here
CAPITAL_PASSWORD=your_password_here
CAPITAL_IDENTIFIER=your_email@example.com
CAPITAL_ENVIRONMENT=live
# Specific account ID (leave empty for auto-detect real account)
CAPITAL_ACCOUNT_ID=

# ── Interactive Brokers (IBKR) ────────────────────────────────
IBKR_CONSUMER_KEY=
IBKR_ACCESS_TOKEN=
IBKR_ACCESS_TOKEN_SECRET=
IBKR_KEYS_DIR=keys
IBKR_ENVIRONMENT=paper

# ── OANDA ─────────────────────────────────────────────────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# ── OpenAI (for AI analysis) ─────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── News APIs ─────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key
NEWSAPI_KEY=your_newsapi_key

# ── Gmail OAuth2 Notifications ───────────────────────────────
# Run: python setup_gmail.py (once, on a machine with browser)
GMAIL_SENDER=your_email@gmail.com
GMAIL_RECIPIENT=your_email@gmail.com
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=

# ── API Security ──────────────────────────────────────────────
# Pre-shared API key. All API requests must include X-API-Key header.
# Generate one with: python3 -c "import secrets; print(f'nt_{secrets.token_urlsafe(48)}')"
API_SECRET_KEY=nt_YOUR_SECURE_KEY_HERE

# ── App Configuration ────────────────────────────────────────
APP_SECRET_KEY=change-this-to-a-random-string
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/neontrade.db
